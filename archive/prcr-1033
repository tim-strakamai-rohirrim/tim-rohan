-- ============================================================================
-- STEP 6: Advance line_item_number sequence past seeded values
-- ============================================================================
DO $$
DECLARE
    seq_name TEXT;
    max_val  BIGINT;
    cur_val  BIGINT;
BEGIN
    seq_name := pg_get_serial_sequence('compliance_items', 'line_item_number');
    SELECT COALESCE(MAX(line_item_number), 0) INTO max_val FROM compliance_items;
    EXECUTE format('SELECT last_value FROM %s', seq_name) INTO cur_val;
    PERFORM setval(seq_name, GREATEST(max_val, cur_val));
END $$;

COMMIT;

