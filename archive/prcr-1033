-- ============================================================================
-- Seed Script: Compliance Phase 1 Data
--
-- Populates compliance_projects, compliance_documents,
-- compliance_project_documents, and compliance_items with deterministic
-- test data for local/staging environments.
--
-- Usage:
--   psql -f rohan_api/scripts/sql/test/seed_compliance.sql
--   Or run directly in pgAdmin / any SQL client.
--
-- Prerequisites:
--   - The compliance tables must already exist (run init_compliance.sql first).
--   - A user with email support@rohirrim.ai must exist in the users table.
--
-- Idempotency:
--   Safe to run multiple times. All rows use fixed UUIDs with prefix
--   00000000-0000-4092- and INSERT … ON CONFLICT … DO UPDATE/NOTHING.
--
-- NOT wired into run_seeds.sql or run_all.sql — run manually.
--
-- Compatible with PostgreSQL 14+
-- ============================================================================

-- ============================================================================
-- STEP 1: Resolve support@rohirrim.ai → user_id
-- ============================================================================
DO $$
DECLARE
    user_email TEXT := 'support@rohirrim.ai';
    system_user_id INTEGER;
BEGIN
    SELECT user_id INTO system_user_id FROM users WHERE email = user_email;
    IF system_user_id IS NULL THEN
        RAISE EXCEPTION 'User with email % not found.', user_email;
    END IF;
    CREATE TEMP TABLE IF NOT EXISTS temp_user_id (user_id INTEGER);
    TRUNCATE temp_user_id;
    INSERT INTO temp_user_id VALUES (system_user_id);
END $$;

BEGIN;

