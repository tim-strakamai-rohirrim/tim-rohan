-- ============================================================================
-- Summary
-- ============================================================================
DO $$
DECLARE
    v_projects  INTEGER;
    v_docs      INTEGER;
    v_proj_docs INTEGER;
    v_items     INTEGER;
BEGIN
    SELECT COUNT(*) INTO v_projects
      FROM compliance_projects
     WHERE id::text LIKE '00000000-0000-4092-a%';

    SELECT COUNT(*) INTO v_docs
      FROM compliance_documents
     WHERE id::text LIKE '00000000-0000-4092-b%';

    SELECT COUNT(*) INTO v_proj_docs
      FROM compliance_project_documents
     WHERE project_id::text LIKE '00000000-0000-4092-a%';

    SELECT COUNT(*) INTO v_items
      FROM compliance_items
     WHERE id::text LIKE '00000000-0000-4092-c%';

    RAISE NOTICE '=== PRCR-1092: Compliance Seed Summary ===';
    RAISE NOTICE 'compliance_projects:          % rows', v_projects;
    RAISE NOTICE 'compliance_documents:         % rows', v_docs;
    RAISE NOTICE 'compliance_project_documents: % rows', v_proj_docs;
    RAISE NOTICE 'compliance_items:             % rows', v_items;
    RAISE NOTICE '=== Done ===';
END $$;
